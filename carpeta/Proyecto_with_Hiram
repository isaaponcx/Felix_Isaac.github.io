<title>The Legend of Zelda - Cronología</title>

<style>
    body{
        margin:0;
        font-family: Arial, sans-serif;
        background-color:#0B3D2E;
        color:#F5F0DC;
    }

    header{
        background-color:#D4AF37;
        color:#0B3D2E;
        text-align:center;
        padding:20px;
        border-bottom:5px solid #083D77;
    }

    h1{
        margin:0;
        font-size:40px;
    }

    .marquesina{
        background:#083D77;
        color:white;
        padding:10px;
        font-weight:bold;
    }

    .contenedor{
        width:80%;
        margin:auto;
        padding:20px;
    }

    .tarjeta{
        background:#145A32;
        margin:20px 0;
        padding:20px;
        border-left:8px solid #D4AF37;
        border-radius:10px;
    }

    h2{
        color:#FFD700;
    }

    ul li{
        margin:10px 0;
    }

    .datos{
        background:#083D77;
        padding:20px;
        border-radius:10px;
    }

    footer{
        text-align:center;
        background:#D4AF37;
        color:#0B3D2E;
        padding:15px;
        margin-top:30px;
        font-weight:bold;
    }

    .triforce{
        text-align:center;
        font-size:60px;
        color:#FFD700;
    }
</style>
